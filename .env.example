# ===============================================================
# Copie este arquivo para .env e preencha com valores reais.
# ===============================================================
ANTHROPIC_API_KEY="your_api_key_here"
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="setor_eletrico"
RERANKER_MODEL="cross-encoder/ms-marco-multilingual-rerank-mmarco-v2"
HF_TOKEN="your_token_here"

# ── Fase 2: Recuperação Híbrida ─────────────────────────────────────────────
# Caminho do índice BM25 persistido (relativo à raiz do projeto)
BM25_INDEX_PATH="data/retrieval/bm25_index.pkl"

# Top-K para cada retriever individualmente
BM25_TOP_K=20
DENSE_TOP_K=20

# Constante k do Reciprocal Rank Fusion (padrão = 60)
RRF_K=60

# Resultados finais após fusão RRF (entrada do reranker)
HYBRID_FINAL_TOP_K=10

# Resultados finais após cross-encoder reranking
RERANKER_TOP_K=5

# Configurações do FastAPI
FASTAPI_PORT=8000

# Configurações do GCP
GCP_BUCKET_PATH="gs://aneel-raw-data/aneel-documents/"

# Embeddings
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MODEL="intfloat/multilingual-e5-large"
EMBEDDING_DEVICE="cpu"

# ── Agente LangGraph ────────────────────────────────────────────────
# LLM
CLAUDE_MODEL="claude-sonnet-4-latest"
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# Agent behavior
MAX_FAITHFULNESS_RETRIES=2
CONTEXT_MAX_TOKENS=6000
MULTIHOP_MAX_ROUNDS=3
HYDE_ENABLED=true
QUERY_REFORMULATIONS=2

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-setor-eletrico
