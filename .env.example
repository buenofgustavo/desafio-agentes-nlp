# ===============================================================
# Copie este arquivo para .env e preencha com valores reais.
# ===============================================================

# ── LLM / Anthropic ─────────────────────────────────────────────────────────
# Chave de API da Anthropic (obrigatório)
ANTHROPIC_API_KEY="your_api_key_here"

# Modelo Claude a usar no agente
CLAUDE_MODEL="claude-haiku-4-5"

# Máximo de tokens na resposta do LLM
LLM_MAX_TOKENS=4096

# Temperatura do LLM (0.0 = determinístico)
LLM_TEMPERATURE=0.0

# ── OpenAI (opcional, não usado no agente principal) ─────────────────────────
OPENAI_API_KEY="your_openai_key_here"
OPENAI_CHAT_MODEL="gpt-4.1-mini"

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN="your_token_here"

# ── Qdrant ───────────────────────────────────────────────────────────────────
# URL do servidor Qdrant (use http://qdrant:6333 dentro do Docker)
QDRANT_URL="http://localhost:6333"

# Nome da coleção Qdrant
QDRANT_COLLECTION="setor_eletrico"

# ── Fase 2: Recuperação Híbrida ─────────────────────────────────────────────
# Caminho do índice BM25 persistido (relativo à raiz do projeto)
BM25_INDEX_PATH="data/retrieval/bm25_index"

# Top-K para cada retriever individualmente
BM25_TOP_K=20
DENSE_TOP_K=20

# Constante k do Reciprocal Rank Fusion (padrão = 60)
RRF_K=60

# Resultados finais após fusão RRF (entrada do reranker)
HYBRID_FINAL_TOP_K=10

# Resultados finais após cross-encoder reranking
RERANKER_TOP_K=5

# Modelo de reranking cross-encoder
RERANKER_MODEL="cross-encoder/mmarco-mMiniLMv2-L12-H384-v1"

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DEVICE="cpu"
EMBEDDING_BATCH_SIZE=64

# ── Fase 4: Agente LangGraph ─────────────────────────────────────────────────
# Número máximo de tentativas de correção de fidelidade
MAX_FAITHFULNESS_RETRIES=2

# Budget máximo de tokens para o contexto montado
CONTEXT_MAX_TOKENS=6000

# Número máximo de rounds de retrieval em queries multi-hop
MULTIHOP_MAX_ROUNDS=3

# Habilitar geração de documento HyDE para expansão de query
HYDE_ENABLED=true

# Número de reformulações de query a gerar
QUERY_REFORMULATIONS=2

# ── Fase 6: API ──────────────────────────────────────────────────────────────
# Endereço e porta da FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_URL="http://api:8000"

# Caminho do relatório de avaliação (relativo ao diretório data/)
EVALUATION_REPORT_PATH="evaluation/final_report.json"

# ── GCP (opcional, para sincronização de dados) ───────────────────────────────
GCP_BUCKET_PATH="gs://aneel-raw-data/aneel-documents/"
