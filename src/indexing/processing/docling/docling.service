[Unit]
Description=Docling GCS Document Parser
After=network-online.target
Wants=network-online.target
After=nvidia-persistenced.service

[Service]
Type=simple
EnvironmentFile=/etc/docling.env

User=root

ExecStart=/opt/docling_env/bin/python3 /opt/docling_parser/parser.py

# One-shot batch job — no automatic restart
# Change to "on-failure" if you want retries on crash
Restart=no

StandardOutput=journal
StandardError=journal
SyslogIdentifier=docling-parser

# Give the process time to finish the current file on shutdown
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
